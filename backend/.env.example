# ── Core ────────────────────────────────────────────────────────────────
# Supabase: use the TRANSACTION POOLER url (IPv4, port 6543). The direct
# db.<ref>.supabase.co host is IPv6-only and unreachable from Railway.
# URL-encode special chars in the password (@ -> %40).
DATABASE_URL=postgresql://postgres.<ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:6543/postgres
PORT=8080
# Public URL of THIS backend. Used to build OAuth callback URLs.
BASE_URL=https://wailist-agentmesh-production.up.railway.app
# Public URL of the frontend. OAuth redirects the browser back here after login.
FRONTEND_URL=https://wailist-agentmesh-zeta.vercel.app

# ── Auth ────────────────────────────────────────────────────────────────
# 32+ bytes. Generate with: openssl rand -hex 32
JWT_SECRET=<openssl rand -hex 32>
# Allowed browser origin for CORS (the frontend).
CORS_ORIGIN=https://wailist-agentmesh-zeta.vercel.app

# ── OAuth ───────────────────────────────────────────────────────────────
# GitHub OAuth App  (https://github.com/settings/developers)
#   Authorization callback URL:
#   https://wailist-agentmesh-production.up.railway.app/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google OAuth client  (https://console.cloud.google.com/apis/credentials)
#   Authorized redirect URI:
#   https://wailist-agentmesh-production.up.railway.app/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Connector account-linking OAuth (issue #32) ─────────────────────────
# Separate app registrations from the login flow above — per-connector API
# scopes, not read:user user:email, and tokens are stored per-workflow-node
# rather than per-user-login.
# Slack app  (https://api.slack.com/apps)
#   Redirect URL: https://wailist-agentmesh-production.up.railway.app/connectors/oauth/slack/callback
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
# GitHub OAuth App, separate registration from GITHUB_CLIENT_ID above
#   (https://github.com/settings/developers)
#   Authorization callback URL:
#   https://wailist-agentmesh-production.up.railway.app/connectors/oauth/github-connector/callback
GITHUB_CONNECTOR_CLIENT_ID=
GITHUB_CONNECTOR_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
TRELLO_CLIENT_ID=
TRELLO_CLIENT_SECRET=
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# ── Encryption (agent wallet mnemonics) ─────────────────────────────────
# 32 hex bytes.
ENCRYPTION_KEY=00000000000000000000000000000000

# ── Algorand ────────────────────────────────────────────────────────────
ALGOD_URL=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
ALGORAND_NETWORK=testnet

# ── AI providers ────────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Payments (Razorpay) ─────────────────────────────────────────────────
# Test-mode keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# From the webhook's own settings page in the dashboard (Settings > Webhooks), not the
# API key secret above. Required so the /payments/razorpay/webhook backstop can verify
# that a payment.captured event genuinely came from Razorpay.
RAZORPAY_WEBHOOK_SECRET=

# ── Discord audit log (optional) ─────────────────────────────────────────
# Discord incoming webhook URLs (Channel Settings > Integrations > Webhooks > New
# Webhook > Copy Webhook URL). Each is independent — leave any blank to disable that
# channel. Alerting is best-effort and never blocks the payment/workflow path it reports on.
# Payment failures: rejected webhook signatures, FX outages, internal errors
# completing/refunding a transaction.
DISCORD_WEBHOOK_PAYMENTS_URL=
# Every successful credit and refund — the money audit trail.
DISCORD_WEBHOOK_CREDITS_URL=
# Every workflow run: started, finished (success/failed/stopped).
DISCORD_WEBHOOK_WORKFLOWS_URL=
